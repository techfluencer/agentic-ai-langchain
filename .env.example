# Your LLM API key. Works with OpenAI directly, or any OpenAI-compatible endpoint.
OPENAI_API_KEY=sk-your-key-here

# Optional — only if you use a compatible endpoint instead of api.openai.com
# (e.g. Azure AI Foundry's OpenAI-compatible "v1" surface)
OPENAI_BASE_URL=https://YOUR-RESOURCE.services.ai.azure.com/openai/v1
